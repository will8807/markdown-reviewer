# SQLite database file paths (relative to project root, resolved by @libsql/client).
# The file is created automatically on first run — no server needed.
DATABASE_URL="file:./prisma/dev.db"

# Separate database for the test suite. Tests truncate between runs, so do not
# point this at the dev DB.
DATABASE_URL_TEST="file:./prisma/test.db"

# Identifier of the seeded mock user. Real auth lands in a later phase; for now
# all writes are attributed to this user. The seed script prints this value.
DEV_USER_ID=
