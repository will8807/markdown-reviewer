# Postgres connection string used by Prisma. Matches docker-compose.yml.
DATABASE_URL="postgresql://markdown_reviewer:markdown_reviewer@localhost:5432/markdown_reviewer?schema=public"

# Separate database for the test suite. Tests truncate between runs, so do not
# point this at the dev DB.
DATABASE_URL_TEST="postgresql://markdown_reviewer:markdown_reviewer@localhost:5432/markdown_reviewer_test?schema=public"

# Identifier of the seeded mock user. Real auth lands in a later phase; for now
# all writes are attributed to this user. The seed script sets this value.
DEV_USER_ID=
